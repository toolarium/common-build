DOCKTERM_VERSION=0.2.0
PN=$(basename "$0" 2>/dev/null)
DOCKTERM_SCRIPT_PATH=$(cd "$(dirname "$0")" 2>/dev/null && pwd)
[ -z "$CB_LINE" ] && CB_LINE="------------------------------------------------------------------------------------------------------------------------"
[ -z "$CB_LINEHEADER" ] && CB_LINEHEADER=".: "
CB_DOCKTERM_CONFIGFILE="$DOCKTERM_SCRIPT_PATH/../conf/dockterm-types.properties"


#########################################################################
# printUsage
#########################################################################
printUsage() {
	echo "$PN - docker term v$DOCKTERM_VERSION"
	echo "usage: $PN [OPTION] [type]"
	echo ""
	echo "Overview of the available OPTIONs:"
	echo " -h, --help           Show this help message."
	echo " -v, --version        Print the version information."
	echo "     --verbose        Verbose output (show pull progress)."
	echo " -k, --keep-image     Keep container after exit (omit --rm)."
	echo " -s, --shell <shell>  Defines the shell, default: /bin/sh."
	echo ""
	echo "The [type] may be given as the numeric menu index or the type name."
	echo "Available types are defined in conf/dockterm-types.properties (key=value"
	echo "format where key is the type name and value is the Docker image)."
	echo ""
	echo "Default types: alpine, arch, debian, fedora, kali, kaliexp, ubuntu"
	echo ""
	echo "To add a custom type, edit conf/dockterm-types.properties:"
	echo "  myimage = registry.example.com/my-dev-image:latest"
	echo "Then run: $PN myimage"
	echo ""
}


#########################################################################
# printVersion
#########################################################################
printVersion() {
	echo "$CB_LINE"
	echo "toolarium dockterm $DOCKTERM_VERSION"
	echo "$CB_LINE"
}


#########################################################################
# Detect container runtime: try nerdctl info first, fall back to docker info
#########################################################################
detectRuntime() {
	if command -v nerdctl >/dev/null 2>&1 && nerdctl info >/dev/null 2>&1; then
		echo "nerdctl"
	elif command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
		echo "docker"
	else
		echo ""
	fi
}


#########################################################################
# Read the configuration (key=value lines only, comments stripped)
#########################################################################
readConfiguration() {
	grep -v '^[[:space:]]*#' "$CB_DOCKTERM_CONFIGFILE" 2>/dev/null | grep '='
}


#########################################################################
# Print dockterm types (numbered)
#########################################################################
printDocktermTypes() {
	local count=1 line key value
	while IFS= read -r line; do
		key="${line%%=*}"
		value="${line#*=}"
		# trim whitespace
		key="${key#"${key%%[![:space:]]*}"}"; key="${key%"${key##*[![:space:]]}"}"
		value="${value#"${value%%[![:space:]]*}"}"; value="${value%"${value##*[![:space:]]}"}"
		printf "   [%s] %-16s %s\n" "$count" "$key" "$value"
		count=$((count+1))
	done < <(readConfiguration)
}


#########################################################################
# Resolve input (index or name) to a type name; prints name or empty
#########################################################################
resolveDocktermType() {
	local input="$1" count=1 line key
	# numeric lookup
	if [ -n "$input" ] && [ "$input" -eq "$input" ] 2>/dev/null; then
		while IFS= read -r line; do
			if [ "$count" = "$input" ]; then
				key="${line%%=*}"
				key="${key#"${key%%[![:space:]]*}"}"; key="${key%"${key##*[![:space:]]}"}"
				echo "$key"
				return 0
			fi
			count=$((count+1))
		done < <(readConfiguration)
		return 1
	fi
	# name lookup
	while IFS= read -r line; do
		key="${line%%=*}"
		key="${key#"${key%%[![:space:]]*}"}"; key="${key%"${key##*[![:space:]]}"}"
		if [ "$key" = "$input" ]; then
			echo "$key"
			return 0
		fi
	done < <(readConfiguration)
	return 1
}


#########################################################################
# Look up the image for a given type name
#########################################################################
getDocktermImage() {
	local wanted="$1" line key value
	while IFS= read -r line; do
		key="${line%%=*}"
		value="${line#*=}"
		key="${key#"${key%%[![:space:]]*}"}"; key="${key%"${key##*[![:space:]]}"}"
		value="${value#"${value%%[![:space:]]*}"}"; value="${value%"${value##*[![:space:]]}"}"
		if [ "$key" = "$wanted" ]; then
			echo "$value"
			return 0
		fi
	done < <(readConfiguration)
	return 1
}


#########################################################################
# Select the dockterm type interactively if not supplied
#########################################################################
selectDocktermType() {
	DOCKTERM_RESOLVED_DIRECTLY="false"
	docktermType=$(resolveDocktermType "$1")
	if [ -n "$docktermType" ]; then
		DOCKTERM_RESOLVED_DIRECTLY="true"
		return 0
	fi

	[ -n "$1" ] && echo "${CB_LINEHEADER}Invalid input $1" && echo ""
	echo "${CB_LINEHEADER}Dockterm type:"
	local input=
	while [ -z "$docktermType" ]; do
		printDocktermTypes
		echo ""
		read -p "${CB_LINEHEADER}Please choose the dockterm type [1]: " input
		[ -z "$input" ] && input=1
		docktermType=$(resolveDocktermType "$input")
		[ -z "$docktermType" ] && echo "${CB_LINEHEADER}Invalid input $input" && echo ""
	done
}


#########################################################################
# main
#########################################################################
DOCKTERM_TYPE_INPUT=""
DOCKTERM_SHELL="/bin/sh"
DOCKTERM_REMOVE_IMAGE="--rm"
DOCKTERM_VERBOSE="false"

while [ $# -gt 0 ]; do
	case "$1" in
		-h|--help)			printUsage; exit 0;;
		-v|--version)		printVersion; exit 0;;
		--verbose)			DOCKTERM_VERBOSE="true";;
		-k|--keep-image)	DOCKTERM_REMOVE_IMAGE="";;
		-s|--shell)			shift; DOCKTERM_SHELL="$1";;
		*)					DOCKTERM_TYPE_INPUT="$1";;
	esac
	shift
done

if [ ! -r "$CB_DOCKTERM_CONFIGFILE" ]; then
	echo "$CB_LINE"
	echo "${CB_LINEHEADER}Missing dockterm configuration file $CB_DOCKTERM_CONFIGFILE!"
	echo "$CB_LINE"
	exit 1
fi

CB_CONTAINER_RUNTIME=$(detectRuntime)
if [ -z "$CB_CONTAINER_RUNTIME" ]; then
	echo "$CB_LINE"
	echo "${CB_LINEHEADER}Neither nerdctl nor docker found in PATH."
	echo "$CB_LINE"
	exit 1
fi
[ "$DOCKTERM_VERBOSE" = "true" ] && echo "${CB_LINEHEADER}Using container runtime: $CB_CONTAINER_RUNTIME"

selectDocktermType "$DOCKTERM_TYPE_INPUT"
if [ -z "$docktermType" ]; then
	echo "$CB_LINE"
	echo "${CB_LINEHEADER}No dockterm selected."
	echo "$CB_LINE"
	exit 1
fi

dockerImage=$(getDocktermImage "$docktermType")
if [ -z "$dockerImage" ]; then
	echo "$CB_LINE"
	echo "${CB_LINEHEADER}Could not find corresponding image for dockterm type $docktermType."
	echo "$CB_LINE"
	exit 1
fi

if [ "$DOCKTERM_RESOLVED_DIRECTLY" = "true" ]; then
	echo "${CB_LINEHEADER}Dockterm type [$CB_CONTAINER_RUNTIME/$docktermType] -> $CB_CONTAINER_RUNTIME run $DOCKTERM_REMOVE_IMAGE --name $docktermType -it -h $docktermType $dockerImage $DOCKTERM_SHELL"
fi

if [ "$DOCKTERM_VERBOSE" = "true" ]; then
	echo "${CB_LINEHEADER}Pulling $dockerImage..."
	"$CB_CONTAINER_RUNTIME" pull "$dockerImage" || exit 1
else
	"$CB_CONTAINER_RUNTIME" pull "$dockerImage" >/dev/null 2>&1 || exit 1
fi

RUN_ARGS=()
[ -n "$DOCKTERM_REMOVE_IMAGE" ] && RUN_ARGS+=("$DOCKTERM_REMOVE_IMAGE")
RUN_ARGS+=(--name "$docktermType" -it -h "$docktermType" "$dockerImage" "$DOCKTERM_SHELL")
"$CB_CONTAINER_RUNTIME" run "${RUN_ARGS[@]}"


#########################################################################
# EOF
#########################################################################
