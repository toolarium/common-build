		PASS=$((PASS+1))
		echo "  PASS: --clean completed"
	fi
}

#########################################################################
# .cb-container config file tests
#########################################################################
test_config_file() {
	echo "TEST: .cb-container config file"
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-ct-cfg-$$")
	mkdir -p "$tmpdir"
	echo "--verbose" > "$tmpdir/.cb-container"
	# run --help from that directory
	output=$(cd "$tmpdir" && "$CT" --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with .cb-container"
	rm -rf "$tmpdir"
}

