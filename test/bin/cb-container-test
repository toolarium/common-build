#########################################################################
# cache behaviour tests (mock docker + trivy via PATH injection)
#########################################################################

# _scanCacheMockSetup <tmpdir> <imgCreated>
# Creates mock docker, nerdctl, and trivy scripts under <tmpdir>/bin.
# imgCreated is the CreatedAt value the mock docker returns.
_scanCacheMockSetup() {
	local tmpdir="$1"
	local imgCreated="${2:-2026-01-01 08:00:00 +0000 UTC}"
	local imageId="testimg1234567890ab"
	local mockbin="$tmpdir/bin"
	mkdir -p "$mockbin"

	# mock docker / nerdctl — handles scan-all list and filter calls
	cat > "$mockbin/docker" <<EOF
#!/usr/bin/env bash
[ "\$1" = "ps" ] && exit 0
[ "\$1" = "images" ] || exit 0
hasFilt=false
for a in "\$@"; do [ "\$a" = "--filter" ] && hasFilt=true; done
if \$hasFilt; then
  fmt="\$3"
  echo "\$fmt" | grep -qF '{{.ID}}' && echo "$imageId"
  echo "\$fmt" | grep -qF '{{.CreatedAt}}' && echo "$imgCreated"
else
  echo "$imageId|mytestrepo|latest|$imgCreated"
fi
exit 0
EOF
	chmod +x "$mockbin/docker"
	cp "$mockbin/docker" "$mockbin/nerdctl"
	chmod +x "$mockbin/nerdctl"

	# mock trivy — outputs valid empty JSON; touches marker if TRIVY_CALLED_MARKER set
	cat > "$mockbin/trivy" <<'EOF'
#!/usr/bin/env bash
printf '{"Results":[]}'
[ -n "$TRIVY_CALLED_MARKER" ] && touch "$TRIVY_CALLED_MARKER"
exit 0
EOF
	chmod +x "$mockbin/trivy"
}

test_scan_cache_filename_extraction() {
	echo "TEST: cache filename day extraction (~-28,8 equivalent)"
	local f1="abc123-20261201-143022-trivy.counts"
	local day1="${f1: -28:8}"
	assertEquals "20261201" "$day1" "day from short imageId filename"

	local f2="abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789-20261201-143022-trivy.counts"
	local day2="${f2: -28:8}"
	assertEquals "20261201" "$day2" "day from long imageId filename"
}

test_scan_all_cache_reuse() {
	echo "TEST: --scan -a cache reuse (trivy not called when cache valid)"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-cache-reuse-$$")
	mkdir -p "$tmpdir"
	_scanCacheMockSetup "$tmpdir"

	local imageId="testimg1234567890ab"
	local cachedir="$tmpdir/cb-container"
	mkdir -p "$cachedir"
	local today
	today=$(date '+%Y%m%d')
	local cacheTs="${today}-120000"
	printf '{"Results":[]}\n' > "$cachedir/${imageId}-${cacheTs}-trivy.json"
	printf '0 0 0 0 0\n'     > "$cachedir/${imageId}-${cacheTs}-trivy.counts"

	local marker="$tmpdir/trivy-called"
	rm -f "$marker"
	CB_TEMP="$tmpdir" TRIVY_CALLED_MARKER="$marker" PATH="$tmpdir/bin:$PATH" \
		"$CT" --scan -a >/dev/null 2>&1

	if [ -f "$marker" ]; then
		FAIL=$((FAIL+1))
		echo "  FAIL: cache reuse - trivy was called but cache was valid"
	else
		PASS=$((PASS+1))
		echo "  PASS: cache reuse - trivy not called (cache hit)"
	fi
	rm -rf "$tmpdir"
}

test_scan_all_cache_day_expired() {
	echo "TEST: --scan -a stale-day cache triggers rescan"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-cache-day-$$")
	mkdir -p "$tmpdir"
	_scanCacheMockSetup "$tmpdir"

	local imageId="testimg1234567890ab"
	local cachedir="$tmpdir/cb-container"
	mkdir -p "$cachedir"
	local yesterday
	yesterday=$(date -d 'yesterday' '+%Y%m%d' 2>/dev/null \
		|| date -v-1d '+%Y%m%d' 2>/dev/null \
		|| echo "19700101")
	local cacheTs="${yesterday}-120000"
	printf '{"Results":[]}\n' > "$cachedir/${imageId}-${cacheTs}-trivy.json"
	printf '0 0 0 0 0\n'     > "$cachedir/${imageId}-${cacheTs}-trivy.counts"

	local marker="$tmpdir/trivy-called"
	rm -f "$marker"
	CB_TEMP="$tmpdir" TRIVY_CALLED_MARKER="$marker" PATH="$tmpdir/bin:$PATH" \
		"$CT" --scan -a >/dev/null 2>&1

	if [ -f "$marker" ]; then
		PASS=$((PASS+1))
		echo "  PASS: stale-day cache - trivy rescanned"
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: stale-day cache - trivy was NOT called (should rescan)"
	fi
	rm -rf "$tmpdir"
}

test_scan_all_cache_image_newer() {
	echo "TEST: --scan -a image-newer-than-cache triggers rescan"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-cache-newer-$$")
	mkdir -p "$tmpdir"
	# image created today at 09:00, cache was written today at 08:00 → stale
	local todayFmt
	todayFmt=$(date '+%Y-%m-%d')
	_scanCacheMockSetup "$tmpdir" "${todayFmt} 09:00:00 +0000 UTC"

	local imageId="testimg1234567890ab"
	local cachedir="$tmpdir/cb-container"
	mkdir -p "$cachedir"
	local today
	today=$(date '+%Y%m%d')
	local cacheTs="${today}-080000"
	printf '{"Results":[]}\n' > "$cachedir/${imageId}-${cacheTs}-trivy.json"
	printf '0 0 0 0 0\n'     > "$cachedir/${imageId}-${cacheTs}-trivy.counts"

	local marker="$tmpdir/trivy-called"
	rm -f "$marker"
	CB_TEMP="$tmpdir" TRIVY_CALLED_MARKER="$marker" PATH="$tmpdir/bin:$PATH" \
		"$CT" --scan -a >/dev/null 2>&1

	if [ -f "$marker" ]; then
		PASS=$((PASS+1))
		echo "  PASS: image-newer cache - trivy rescanned"
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: image-newer cache - trivy was NOT called (should rescan)"
	fi
	rm -rf "$tmpdir"
}

