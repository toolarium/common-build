#########################################################################
# settings.gradle auto-detection tests
#########################################################################
test_settings_gradle_single_quotes() {
	echo "TEST: settings.gradle with single quotes"
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-ct-sg1-$$")
	mkdir -p "$tmpdir"
	echo "rootProject.name = 'my-gradle-project'" > "$tmpdir/settings.gradle"
	output=$(cd "$tmpdir" && "$CT" --scan 2>&1)
	assertContains "my-gradle-project" "$output" "resolves single-quoted project name"
	rm -rf "$tmpdir"
}

test_settings_gradle_double_quotes() {
	echo "TEST: settings.gradle with double quotes"
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-ct-sg2-$$")
	mkdir -p "$tmpdir"
	printf 'rootProject.name = "my-dq-project"\n' > "$tmpdir/settings.gradle"
	output=$(cd "$tmpdir" && "$CT" --scan 2>&1)
	assertContains "my-dq-project" "$output" "resolves double-quoted project name"
	rm -rf "$tmpdir"
}

test_settings_gradle_no_spaces() {
	echo "TEST: settings.gradle without spaces around ="
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-ct-sg3-$$")
	mkdir -p "$tmpdir"
	echo "rootProject.name='compact-name'" > "$tmpdir/settings.gradle"
	output=$(cd "$tmpdir" && "$CT" --scan 2>&1)
	assertContains "compact-name" "$output" "resolves name without spaces"
	rm -rf "$tmpdir"
}

test_settings_gradle_tabs() {
	echo "TEST: settings.gradle with tabs"
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-ct-sg4-$$")
	mkdir -p "$tmpdir"
	printf "rootProject.name\t=\t'tabbed-project'\n" > "$tmpdir/settings.gradle"
	output=$(cd "$tmpdir" && "$CT" --scan 2>&1)
	assertContains "tabbed-project" "$output" "resolves name with tabs"
	rm -rf "$tmpdir"
}

test_no_settings_gradle() {
	echo "TEST: no settings.gradle shows error"
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-ct-sg5-$$")
	mkdir -p "$tmpdir"
	output=$(cd "$tmpdir" && "$CT" --scan 2>&1)
	# should not crash, either show 'auto' not found or no images
	assertNotContains "FATAL" "$output" "no crash without settings.gradle"
	rm -rf "$tmpdir"
}

#########################################################################
# scan-all tests
#########################################################################
test_scan_all() {
	echo "TEST: --scan -a shows VULN column"
	output=$("$CT" --scan -a 2>&1)
	exitCode=$?
	if [ $exitCode -eq 0 ]; then
		assertContains "CRIT" "$output" "--scan -a header has CRIT column"
		assertContains "IMAGE ID" "$output" "--scan -a header has IMAGE ID"
		assertContains "TAG" "$output" "--scan -a header has TAG"
		assertNotContains "SIZE" "$output" "--scan -a does not show SIZE"
	else
		PASS=$((PASS+1))
		echo "  PASS: --scan -a skipped (no container runtime or trivy)"
	fi
}

