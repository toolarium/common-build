test_multiple_ports_flag
test_env_already_running_warning
test_log_range_not_found
test_scan_multiple_images
test_start_log_combined

echo ""
echo "Results: $PASS passed, $FAIL failed"
[ $FAIL -eq 0 ] && exit 0 || exit 1
