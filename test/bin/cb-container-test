#########################################################################
# remote registry tests (flag acceptance and help, no network calls)
#########################################################################
test_registry_flag() {
	echo "TEST: --registry flag accepted"
	output=$("$CT" --registry https://reg.example.com --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with --registry --help"
}

test_help_registry() {
	echo "TEST: help lists --registry"
	output=$("$CT" --help 2>&1)
	assertContains "--registry" "$output" "help lists --registry"
	assertContains "CB_REGISTRY_USER" "$output" "help mentions CB_REGISTRY_USER"
	assertContains "CB_REGISTRY_PASSWORD" "$output" "help mentions CB_REGISTRY_PASSWORD"
	assertContains "Docker Registry v2" "$output" "help mentions Docker Registry v2"
}

test_registry_list_requires_repo() {
	echo "TEST: --list --registry without repo shows error"
	output=$("$CT" --list --registry https://reg.example.com 2>&1)
	exitCode=$?
	assertEquals "1" "$exitCode" "exit code 1 when repo missing"
	assertContains "Repository name required" "$output" "shows repo required message"
}

test_registry_list_requires_credentials() {
	echo "TEST: --list --registry without credentials shows error"
	# unset credentials to ensure clean test
	output=$(unset CB_REGISTRY_USER CB_REGISTRY_PASSWORD && "$CT" --list myrepo --registry https://reg.example.com 2>&1)
	exitCode=$?
	assertEquals "1" "$exitCode" "exit code 1 when credentials missing"
	assertContains "credentials not set" "$output" "shows credentials error"
}

test_registry_scan_requires_credentials() {
	echo "TEST: --scan --registry without credentials shows error"
	output=$(unset CB_REGISTRY_USER CB_REGISTRY_PASSWORD && "$CT" --scan myapp:latest --registry https://reg.example.com 2>&1)
	exitCode=$?
	assertEquals "1" "$exitCode" "exit code 1 when credentials missing for scan"
	assertContains "credentials not set" "$output" "shows credentials error for scan"
}

test_registry_combined_flags() {
	echo "TEST: --registry combined with other flags accepted"
	output=$("$CT" --registry https://reg.example.com --wide --force --csv --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with --registry and other flags"
	assertContains "usage:" "$output" "combined registry flags do not break --help"
}

