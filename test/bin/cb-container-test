#########################################################################
# verbose / env tests (mock docker/nerdctl)
#########################################################################

# _startMockSetup <tmpdir>
# Creates mock docker and nerdctl scripts that return empty for ps/images,
# exit 0 for rm, and output a fake container ID for run.
_startMockSetup() {
	local tmpdir="$1"
	local mockbin="$tmpdir/bin"
	mkdir -p "$mockbin"
	cat > "$mockbin/docker" <<'EOF'
#!/usr/bin/env bash
[ "$1" = "ps" ]     && exit 0
[ "$1" = "images" ] && exit 0
[ "$1" = "rm" ]     && exit 0
echo "mockcid123456"
exit 0
EOF
	chmod +x "$mockbin/docker"
	cp "$mockbin/docker" "$mockbin/nerdctl"
	chmod +x "$mockbin/nerdctl"
}

test_help_inside_project_example() {
	echo "TEST: help contains 'Inside a project' example"
	output=$("$CT" --help 2>&1)
	assertContains "Inside a project" "$output" "help shows 'Inside a project' section"
	assertContains "SUBPATH=ooo --start" "$output" "help shows env+start example"
}

test_verbose_start_shows_execute() {
	echo "TEST: --verbose --start shows Execute: line"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-vstart-$$")
	_startMockSetup "$tmpdir"
	output=$(CB_TEMP="$tmpdir" PATH="$tmpdir/bin:$PATH" "$CT" --verbose --start testimage:latest 2>&1)
	assertContains "Execute:" "$output" "--verbose --start shows Execute: line"
	rm -rf "$tmpdir"
}

test_env_value_in_execute() {
	echo "TEST: --env SUBPATH=ooo shows -e SUBPATH=ooo in Execute line"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-envexec-$$")
	_startMockSetup "$tmpdir"
	output=$(CB_TEMP="$tmpdir" PATH="$tmpdir/bin:$PATH" "$CT" --verbose --env SUBPATH=ooo --start testimage:latest 2>&1)
	assertContains "Execute:" "$output" "--verbose --env --start shows Execute: line"
	assertContains "-e SUBPATH=ooo" "$output" "--env SUBPATH=ooo produces -e SUBPATH=ooo in Execute"
	rm -rf "$tmpdir"
}

test_env_multiple_values_in_execute() {
	echo "TEST: --env KEY1=val1,KEY2=val2 shows both -e args in Execute line"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-envmulti-$$")
	_startMockSetup "$tmpdir"
	output=$(CB_TEMP="$tmpdir" PATH="$tmpdir/bin:$PATH" "$CT" --verbose --env KEY1=val1,KEY2=val2 --start testimage:latest 2>&1)
	assertContains "Execute:" "$output" "--verbose multi-env --start shows Execute:"
	assertContains "-e KEY1=val1" "$output" "multi env shows -e KEY1=val1"
	assertContains "-e KEY2=val2" "$output" "multi env shows -e KEY2=val2"
	rm -rf "$tmpdir"
}

test_help_inside_project_example
test_verbose_start_shows_execute
test_env_value_in_execute
test_env_multiple_values_in_execute

#########################################################################
# flag acceptance gap tests
#########################################################################

test_tail_flag() {
	echo "TEST: -t/--tail flag accepted"
	output=$("$CT" --tail --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with --tail --help"
	assertContains "usage:" "$output" "--tail does not prevent --help"
}

test_all_flag() {
	echo "TEST: -a/--all flag accepted"
	output=$("$CT" -a --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with -a --help"
	output=$("$CT" --all --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with --all --help"
}

test_it_flag() {
	echo "TEST: -i/--it flag accepted"
	output=$("$CT" -i ubuntu --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with -i <image> --help"
	output=$("$CT" --it ubuntu --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with --it <image> --help"
}

test_port_colon_flag() {
	echo "TEST: -p port:port (colon syntax) accepted"
	output=$("$CT" -p 8081:8082 --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with -p 8081:8082 --help"
}

test_multiple_ports_flag() {
	echo "TEST: multiple -p flags accepted"
	output=$("$CT" -p 8080 -p 9090 --help 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0 with -p 8080 -p 9090 --help"
}

#########################################################################
# --env already-running container warning test
#########################################################################

test_env_already_running_warning() {
	echo "TEST: --env with already-running container shows warning"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-envrun-$$")
	local mockbin="$tmpdir/bin"
	mkdir -p "$mockbin"
	# mock ps returns a running container matching testimage:latest
	cat > "$mockbin/docker" <<'EOF'
#!/usr/bin/env bash
if [ "$1" = "ps" ]; then
    echo "abc123def456|testimage:latest"
    exit 0
fi
[ "$1" = "images" ] && exit 0
[ "$1" = "rm" ] && exit 0
echo "mockcid123456"
exit 0
EOF
	chmod +x "$mockbin/docker"
	cp "$mockbin/docker" "$mockbin/nerdctl"
	chmod +x "$mockbin/nerdctl"
	output=$(CB_TEMP="$tmpdir" PATH="$tmpdir/bin:$PATH" "$CT" --env MYKEY=val --start testimage:latest 2>&1)
	assertContains "already running" "$output" "--env with running container shows 'already running'"
	assertContains "no effect" "$output" "--env with running container shows env-has-no-effect warning"
	rm -rf "$tmpdir"
}

#########################################################################
# --log line-range tests
#########################################################################

test_log_range_not_found() {
	echo "TEST: --log with line ranges (10, 5-10, 5-) does not crash"
	local output exitCode
	output=$("$CT" --log nonexistent-log-xyz 10 2>&1)
	exitCode=$?
	if [ $exitCode -ne 0 ]; then
		assertContains "not found" "$output" "--log img 10 shows not found"
	else
		PASS=$((PASS+1))
		echo "  PASS: --log img 10 handled (runtime available)"
	fi
	output=$("$CT" --log nonexistent-log-xyz 5-10 2>&1)
	exitCode=$?
	if [ $exitCode -ne 0 ]; then
		assertContains "not found" "$output" "--log img 5-10 shows not found"
	else
		PASS=$((PASS+1))
		echo "  PASS: --log img 5-10 handled (runtime available)"
	fi
	output=$("$CT" --log nonexistent-log-xyz 5- 2>&1)
	exitCode=$?
	if [ $exitCode -ne 0 ]; then
		assertContains "not found" "$output" "--log img 5- shows not found"
	else
		PASS=$((PASS+1))
		echo "  PASS: --log img 5- handled (runtime available)"
	fi
}

#########################################################################
# --scan comma-separated multi-image test
#########################################################################

test_scan_multiple_images() {
	echo "TEST: --scan img1,img2 parsed correctly (comma-separated filter)"
	local output exitCode
	output=$("$CT" --scan nonexistent-scan-xyz1,nonexistent-scan-xyz2 2>&1)
	exitCode=$?
	# comma-separated targets are treated as scan-all with filter; both names filter to 0 results
	assertNotContains "Invalid parameter" "$output" "multi-scan not treated as invalid parameter"
	if [ $exitCode -eq 0 ]; then
		assertContains "image(s)" "$output" "multi-scan shows image count"
	else
		PASS=$((PASS+1))
		echo "  PASS: --scan multiple shows error (no runtime or images not found)"
	fi
}

#########################################################################
# --start --log combined (in-project auto-detect)
#########################################################################

test_start_log_combined() {
	echo "TEST: --start --log combined auto-detects project name"
	local tmpdir
	tmpdir=$(mktemp -d 2>/dev/null || echo "/tmp/cb-stlog-$$")
	mkdir -p "$tmpdir"
	echo "rootProject.name = 'auto-stlog-project'" > "$tmpdir/settings.gradle"
	output=$(cd "$tmpdir" && "$CT" --start --log 2>&1)
	assertContains "auto-stlog-project" "$output" "--start --log shows project name from settings.gradle"
	rm -rf "$tmpdir"
}

test_tail_flag
