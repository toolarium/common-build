#!/bin/bash

#########################################################################
#
# cb-lock-unlock-test
#
# Tests for bin/include/lock-unlock.sh: lock creation, unlock removal,
# stale lock timeout, nonexistent file handling.
#
#########################################################################

SCRIPT_DIR=$(cd -- "$(dirname "$0")" 2>/dev/null && pwd)
SRC_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
PASS=0
FAIL=0

TMPDIR=$(mktemp -d 2>/dev/null || echo "/tmp/cb-lock-unlock-test-$$")
mkdir -p "$TMPDIR"
trap 'rm -rf "$TMPDIR"' EXIT

assertEquals() {
	local expected="$1" actual="$2" msg="$3"
	if [ "$expected" = "$actual" ]; then
		PASS=$((PASS+1))
		echo "  PASS: $msg"
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: $msg (expected [$expected], got [$actual])"
	fi
}

#########################################################################
# tests
#########################################################################
test_lock_creates_file() {
	echo "TEST: lock creates lock file"
	local lf="$TMPDIR/test.lock"
	rm -f "$lf"
	CB_INSTALL_SILENT=true . "$SRC_ROOT/bin/include/lock-unlock.sh" "$lf" 60
	if [ -f "$lf" ]; then
		PASS=$((PASS+1))
		echo "  PASS: lock file created"
		# verify format: timestamp=pid
		content=$(cat "$lf")
		if echo "$content" | grep -qE '^[0-9]+='; then
			PASS=$((PASS+1))
			echo "  PASS: lock file has correct format (timestamp=pid)"
		else
			FAIL=$((FAIL+1))
			echo "  FAIL: lock file format incorrect: $content"
		fi
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: lock file not created"
	fi
	rm -f "$lf"
}

test_unlock_removes_file() {
	echo "TEST: unlock removes lock file"
	local lf="$TMPDIR/test-unlock.lock"
	echo "12345=$$" > "$lf"
	CB_INSTALL_SILENT=true . "$SRC_ROOT/bin/include/lock-unlock.sh" --unlock "$lf"
	if [ ! -f "$lf" ]; then
		PASS=$((PASS+1))
		echo "  PASS: lock file removed"
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: lock file still exists after unlock"
	fi
}

test_lock_stale_timeout() {
	echo "TEST: stale lock is overwritten after timeout"
	local lf="$TMPDIR/test-stale.lock"
	# Create a lock with a very old timestamp (epoch 0) and different PID
	echo "0=99999" > "$lf"
	CB_INSTALL_SILENT=true . "$SRC_ROOT/bin/include/lock-unlock.sh" "$lf" 60
	if [ -f "$lf" ]; then
		content=$(cat "$lf")
		if echo "$content" | grep -q "99999"; then
			FAIL=$((FAIL+1))
			echo "  FAIL: stale lock not overwritten"
		else
			PASS=$((PASS+1))
			echo "  PASS: stale lock overwritten with new PID"
		fi
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: lock file missing after stale override"
	fi
	rm -f "$lf"
}

test_unlock_nonexistent() {
	echo "TEST: unlock on nonexistent file does not error"
	local lf="$TMPDIR/nonexistent.lock"
	rm -f "$lf"
	CB_INSTALL_SILENT=true . "$SRC_ROOT/bin/include/lock-unlock.sh" --unlock "$lf"
	PASS=$((PASS+1))
	echo "  PASS: unlock on missing file did not crash"
}

test_lock_no_args() {
	echo "TEST: lock-unlock.sh with no args exits silently"
	(CB_INSTALL_SILENT=true . "$SRC_ROOT/bin/include/lock-unlock.sh" 2>/dev/null)
	PASS=$((PASS+1))
	echo "  PASS: no args exits without error"
}

#########################################################################
# main
#########################################################################
echo "Running cb-lock-unlock tests..."
echo "Using: $SRC_ROOT/bin/include/lock-unlock.sh"
echo ""

test_lock_creates_file
test_unlock_removes_file
test_lock_stale_timeout
test_unlock_nonexistent
test_lock_no_args

echo ""
echo "Results: $PASS passed, $FAIL failed"
[ $FAIL -eq 0 ] && exit 0 || exit 1
