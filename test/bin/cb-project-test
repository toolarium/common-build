#!/bin/bash

#########################################################################
#
# cb-project-test
#
# Tests project scaffolding via 'cb --new' for every project type
# defined in conf/project-types.properties, then optionally runs the
# build via 'cb' in the created project directory.
#
# Tool prerequisites (java, gradle, node) are linked from external
# installs or installed into the temp sandbox — NEVER into the repo.
#
# Gates:
#   default                       scaffold-only for Groups A+B
#   CB_PROJECT_TEST_BUILD=1       add build phase for A+B
#   CB_PROJECT_TEST_NETWORK=1     add Group C (vuejs, nuxtjs, react)
#   both                          full matrix
#
#########################################################################

SCRIPT_DIR=$(cd -- "$(dirname "$0")" 2>/dev/null && pwd)
SRC_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
PASS=0
FAIL=0
SKIP=0
[ -z "$CB_PROJECT_SCAFFOLD_TIMEOUT" ] && CB_PROJECT_SCAFFOLD_TIMEOUT=60

#########################################################################
# Install common-build into sandbox via cb-install
# This ensures wget/unzip/cb-json and all required tools are in place.
#########################################################################
SANDBOX_DEVTOOLS=$(mktemp -d 2>/dev/null || echo "/tmp/cb-project-devtools-$$")
echo "Setting up sandbox via cb-install..."
env -i \
	PATH="$PATH" \
	HOME="${HOME}" \
	USER="${USER:-tester}" \
	SHELL="${SHELL:-/bin/bash}" \
	GITHUB_TOKEN="${GITHUB_TOKEN:-}" \
	CB_DEVTOOLS="$SANDBOX_DEVTOOLS" \
	"$SRC_ROOT/bin/cb-install" --silent --force >/dev/null 2>&1

SANDBOX_HOME=""
for d in "$SANDBOX_DEVTOOLS"/toolarium-common-build-*; do
	[ -d "$d" ] && SANDBOX_HOME="$d" && break
done
if [ -z "$SANDBOX_HOME" ] || [ ! -d "$SANDBOX_HOME" ]; then
	echo "ERROR: cb-install failed — no install directory under $SANDBOX_DEVTOOLS"
	exit 1
fi
export CB_HOME="$SANDBOX_HOME"
CB="$SANDBOX_HOME/bin/cb"

#########################################################################
# Install tools into sandbox via cb --install
#########################################################################
installTool() {
	local toolName="$1"
	local installLog="$SANDBOX_HOME/install-${toolName}.log"

	echo "  -> installing $toolName via cb --install (into sandbox)..."
	"$CB" --install "$toolName" --default >"$installLog" 2>&1
	if [ -d "$SANDBOX_HOME/current/$toolName/bin" ] || [ -d "$SANDBOX_HOME/current/$toolName" ]; then
		echo "  -> $toolName installed into sandbox"
		return 0
	fi

	echo "  -> WARNING: $toolName install failed, log:"
	cat "$installLog" 2>/dev/null
	return 1
}

echo "Setting up sandbox tools..."
installTool java
installTool gradle

HAS_JAVA=false
HAS_GRADLE=false
HAS_NODE=false
( [ -d "$SANDBOX_HOME/current/java/bin" ] || [ -d "$SANDBOX_HOME/current/java" ] )     && HAS_JAVA=true
( [ -d "$SANDBOX_HOME/current/gradle/bin" ] || [ -d "$SANDBOX_HOME/current/gradle" ] ) && HAS_GRADLE=true

if [ "$CB_PROJECT_TEST_NETWORK" = "1" ]; then
	installTool node
	[ -d "$SANDBOX_HOME/current/node" ] && HAS_NODE=true
fi

#########################################################################
# Sandbox for project creation
#########################################################################
SANDBOX=$(mktemp -d 2>/dev/null || echo "/tmp/cb-project-test-$$")
mkdir -p "$SANDBOX" || { echo "ERROR: could not create sandbox $SANDBOX"; exit 1; }
LOGDIR="$SANDBOX/logs"
mkdir -p "$LOGDIR"

cleanup() {
	[ -n "$SANDBOX" ] && [ -d "$SANDBOX" ] && rm -rf "$SANDBOX" >/dev/null 2>&1
	[ -n "$SANDBOX_DEVTOOLS" ] && [ -d "$SANDBOX_DEVTOOLS" ] && rm -rf "$SANDBOX_DEVTOOLS" >/dev/null 2>&1
}
trap cleanup EXIT INT TERM

#########################################################################
# assertion helpers
#########################################################################
assertDirExists() {
	local d="$1" msg="$2"
	if [ -d "$d" ]; then
		PASS=$((PASS+1))
		echo "  PASS: $msg"
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: $msg (dir missing: $d)"
	fi
}

assertScaffoldFile() {
	local dir="$1" msg="$2"
	for f in build.gradle settings.gradle README.md package.json; do
		if [ -f "$dir/$f" ]; then
			PASS=$((PASS+1))
			echo "  PASS: $msg ($f)"
			return
		fi
	done
	FAIL=$((FAIL+1))
	echo "  FAIL: $msg (no scaffold file in $dir)"
}

assertBuildSuccess() {
	local exitCode="$1" logFile="$2" msg="$3"
	if [ "$exitCode" = "0" ]; then
		PASS=$((PASS+1))
		echo "  PASS: $msg"
	else
		FAIL=$((FAIL+1))
		echo "  FAIL: $msg (exit code $exitCode, log: $logFile)"
		# show last 10 lines on failure
		tail -10 "$logFile" 2>/dev/null | sed 's/^/    | /'
	fi
}

#########################################################################
# Run a command with a timeout (portable: Linux + macOS)
# Args: seconds command [args...]
#########################################################################
runWithTimeout() {
	local secs="$1"; shift
	"$@" &
	local pid=$!
	( sleep "$secs" && kill "$pid" 2>/dev/null ) &
	local timer=$!
	wait "$pid" 2>/dev/null
	kill "$timer" 2>/dev/null
	wait "$timer" 2>/dev/null
}

#########################################################################
# Run one project type: scaffold + optional build
# Args: typeId projectName label extraArg1 ...
#########################################################################
runProjectType() {
	local typeId="$1" projectName="$2" label="$3"
	shift 3
	local subDir="$SANDBOX/type${typeId}-${label}"
	mkdir -p "$subDir" >/dev/null 2>&1

	echo "TEST: cb --new $typeId ($label)"

	# Phase 1: scaffold — timeout keeps CI fast; the directory and
	# build.gradle are created before the (slow) Gradle download starts,
	# so a short timeout is enough for the scaffold assertions.
	( cd "$subDir" && runWithTimeout "$CB_PROJECT_SCAFFOLD_TIMEOUT" "$CB" --new "$typeId" "$projectName" "$@" >/dev/null 2>&1 )
	local projectDir="$subDir/$projectName"
	assertDirExists    "$projectDir" "scaffold: project directory created"
	assertScaffoldFile "$projectDir" "scaffold: file present"

	# Phase 2: build (optional)
	if [ "$CB_PROJECT_TEST_BUILD" = "1" ] && [ -d "$projectDir" ]; then
		if [ "$HAS_GRADLE" = "true" ] || [ "$HAS_NODE" = "true" ]; then
			local logFile="$LOGDIR/build-type${typeId}-${label}.log"
			( cd "$projectDir" && "$CB" --silent >"$logFile" 2>&1 )
			assertBuildSuccess "$?" "$logFile" "build: cb exit 0"
		else
			SKIP=$((SKIP+1))
			echo "  SKIP: build phase (gradle/node not available)"
		fi
	elif [ "$CB_PROJECT_TEST_BUILD" != "1" ]; then
		SKIP=$((SKIP+1))
		echo "  SKIP: build phase (set CB_PROJECT_TEST_BUILD=1)"
	fi
}

labelFor() {
	local id="$1"
	grep -v '^#' "$SRC_ROOT/conf/project-types.properties" 2>/dev/null \
		| grep '=' \
		| awk -F= -v want="$id" 'NR==want{print $1}' \
		| sed 's/[[:space:]]*$//'
}

#########################################################################
# main
#########################################################################
echo ""
echo "Running cb project-creation tests..."
echo "Using:   $CB"
echo "CB_HOME: $CB_HOME"
echo "Sandbox: $SANDBOX"
echo "Java:    $HAS_JAVA  Gradle: $HAS_GRADLE  Node: $HAS_NODE"
echo "Flags:   BUILD=$CB_PROJECT_TEST_BUILD  NETWORK=$CB_PROJECT_TEST_NETWORK"
echo ""

[ ! -x "$CB" ] && echo "ERROR: $CB not found or not executable" && exit 1

if [ "$HAS_JAVA" != "true" ]; then
	echo "FAIL: java not available — cb --install java failed."
	exit 1
fi
if [ "$HAS_GRADLE" != "true" ]; then
	echo "FAIL: gradle not available — cb --install gradle failed."
	exit 1
fi

echo "========================================="
echo "Group A+B: Gradle-based project types"
echo "========================================="
echo ""

# Group A — Gradle + Java
runProjectType 1  "my-test"                     "$(labelFor 1)"  my.rootpackage.name my my test-description
runProjectType 2  "my-lib"                      "$(labelFor 2)"  my.rootpackage.name my my test-description
runProjectType 5  "my-test-service-api-spec"    "$(labelFor 5)"  my.rootpackage.name my my test-description
runProjectType 6  "my-test-service"             "$(labelFor 6)"  my.rootpackage.name my my test-description

# Group B — Gradle-only
runProjectType 3  "my-test-config"              "$(labelFor 3)"  my my test-description
runProjectType 4  "my-test-bin"                 "$(labelFor 4)"  my test-description
runProjectType 10 "my-test-app"                 "$(labelFor 10)" my my test-description
runProjectType 11 "my-test-documentation"       "$(labelFor 11)" my test-description
runProjectType 12 "my-test-container"           "$(labelFor 12)" my test-description
runProjectType 13 "my-test-org-config"          "$(labelFor 13)" my test-description

if [ "$CB_PROJECT_TEST_NETWORK" = "1" ]; then
	if [ "$HAS_NODE" != "true" ]; then
		echo "FAIL: node not available — cb --install node failed."
		exit 1
	fi
	echo ""
	echo "========================================="
	echo "Group C: Node-based project types"
	echo "========================================="
	echo ""
	runProjectType 7 "my-test-vue-ui"   "$(labelFor 7)" my test-description
	runProjectType 8 "my-test-nuxt-ui"  "$(labelFor 8)" my test-description
	runProjectType 9 "my-test-react-ui" "$(labelFor 9)" my test-description
else
	echo ""
	echo "SKIP: Group C (vuejs, nuxtjs, react) — set CB_PROJECT_TEST_NETWORK=1"
	SKIP=$((SKIP+3))
fi

echo ""
echo "========================================="
echo "Results: $PASS passed, $FAIL failed, $SKIP skipped"
echo "========================================="
[ $FAIL -eq 0 ] && exit 0 || exit 1
