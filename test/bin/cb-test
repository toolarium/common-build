test_setenv_detects_java() {
	echo "TEST: setCBEnv adds java to PATH when present"
	# Create a mock java directory under current/
	mkdir -p "$SANDBOX_HOME/current/java/bin"
	# Create a fake javac binary
	echo '#!/bin/sh' > "$SANDBOX_HOME/current/java/bin/javac"
	chmod +x "$SANDBOX_HOME/current/java/bin/javac"
	output=$("$CB" --setenv 2>&1)
	exitCode=$?
	assertEquals "0" "$exitCode" "exit code 0"
	assertContains "java" "$output" "setenv mentions java"
	rm -rf "$SANDBOX_HOME/current/java"
}

